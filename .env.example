# ============================================================================
# MonCTL Environment Variables
# ============================================================================
# Copy this file and create the .env files listed below for your deployment.
# Generate secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Required .env files per component:
#   .env.secrets          — shared secrets (used by central-ha compose)
#   .env.central          — central single-node (central4)
#   .env.collector-N      — one per collector node (N = 1..4)
#   .env.local-dev        — playwright/test credentials (not deployed)
#
# Each compose project reads its .env from the deploy directory on the server.
# The deploy script copies the relevant .env file to the target node.
# ============================================================================


# ── Shared Secrets (.env.secrets) ────────────────────────────────────────────
# Used by: docker-compose.central-ha.yml (central1-3)

# AES-256-GCM key for credential encryption (64-char hex = 32 bytes)
ENCRYPTION_KEY=<generate-with-secrets-token-hex-32>

# JWT signing key (64-char hex)
JWT_SECRET=<generate-with-secrets-token-hex-32>

# Shared API key for collector → central authentication
COLLECTOR_API_KEY=<generate-with-secrets-token-hex-32>

# PostgreSQL superuser password
PG_PASSWORD=<strong-random-password>

# PostgreSQL replication password (Patroni)
PG_REPL_PASSWORD=<strong-random-password>

# Initial admin user password (only used on first startup)
ADMIN_PASSWORD=<strong-random-password>


# ── Central HA Node Config ───────────────────────────────────────────────────
# Set per-node in the .env deployed to each central server.
# Used by: docker-compose.central-ha.yml

# Node identity
PATRONI_NAME=pg1                        # pg1 on central1, pg2 on central2
NODE_IP=10.0.0.1                        # this node's IP
MONCTL_NODE_NAME=central1               # human-readable name for health UI
MONCTL_ROLE=all                         # "all" on central1 (runs scheduler), "api" on others

# PostgreSQL
PG_HOST=10.0.0.1                        # Patroni leader IP (central1 default)

# Redis Sentinel (central1-3 run sentinels)
MONCTL_REDIS_SENTINEL_HOSTS=10.0.0.1:26379,10.0.0.2:26379,10.0.0.3:26379
MONCTL_REDIS_SENTINEL_MASTER=monctl-redis
REDIS_HOST=10.0.0.1                     # direct Redis host (fallback)

# ClickHouse cluster nodes
CLICKHOUSE_HOSTS=10.0.0.3,10.0.0.4
MONCTL_CLICKHOUSE_USER=monctl
MONCTL_CLICKHOUSE_PASSWORD=monctl

# Infrastructure health check topology (name:ip pairs)
MONCTL_PATRONI_NODES=central1:10.0.0.1,central2:10.0.0.2
MONCTL_ETCD_NODES=central1:10.0.0.1,central2:10.0.0.2,central3:10.0.0.3

# Docker stats sidecar endpoints (label:ip:port)
MONCTL_DOCKER_STATS_HOSTS=central1:10.0.0.1:9100,central2:10.0.0.2:9100


# ── Central Single-Node (.env.central) ──────────────────────────────────────
# Used by: docker-compose.central-prod.yml (central4)
# Needs: PG_PASSWORD, ENCRYPTION_KEY, JWT_SECRET, COLLECTOR_API_KEY, ADMIN_PASSWORD
# (same values as .env.secrets)


# TLS Subject Alternative Names (all IPs that may serve the UI)
MONCTL_TLS_SAN_IPS=10.0.0.40,10.0.0.1,10.0.0.2,10.0.0.3,10.0.0.4


# ── etcd (.env per node) ─────────────────────────────────────────────────────
# Used by: docker-compose.etcd.yml (central1-3)

ETCD_NAME=etcd1                         # etcd1, etcd2, etcd3
ETCD_ADVERTISE_IP=10.0.0.1             # this node's IP
ETCD_INITIAL_CLUSTER=etcd1=http://10.0.0.1:2380,etcd2=http://10.0.0.2:2380,etcd3=http://10.0.0.3:2380

# Patroni etcd connection (used by central-ha Patroni service)
PATRONI_ETCD3_HOSTS=10.0.0.1:2379,10.0.0.2:2379,10.0.0.3:2379

# Redis primary host (used by redis-replica service)
REDIS_PRIMARY_HOST=10.0.0.1            # IP of central node running Redis primary


# ── ClickHouse (.env per node) ───────────────────────────────────────────────
# Used by: docker-compose.clickhouse.yml (central3-4)

CLICKHOUSE_PASSWORD=monctl
CLICKHOUSE_REPLICA=ch1                  # ch1 on central3, ch2 on central4
KEEPER_SERVER_ID=1                      # 1 on central3, 2 on central4
INTERSERVER_HTTP_HOST=10.0.0.3          # this node's IP


# ── HAProxy / Keepalived (.env per node) ─────────────────────────────────────
# Used by: docker-compose.haproxy.yml (all central nodes)

KEEPALIVED_INTERFACE=eth0               # network interface for VIP
KEEPALIVED_PRIORITY=100                 # highest priority node becomes VIP master (97-100)


# ── Collector (.env.collector-N) ─────────────────────────────────────────────
# Used by: docker-compose.collector-prod.yml (worker1-4)

NODE_ID=collector-01                    # unique per collector node
CENTRAL_URL=https://10.0.0.40           # VIP or direct central URL
CENTRAL_API_KEY=<same-as-COLLECTOR_API_KEY>
VERIFY_SSL=false                        # false for self-signed certs
MONCTL_ADVERTISE_ADDR=10.0.0.31:50051   # this node's gRPC address
MONCTL_COLLECTOR_ID=                    # UUID from central after registration (optional)

# Docker stats push (collector sidecar)
DOCKER_STATS_PUSH_URL=https://10.0.0.40/api/v1/docker-stats/push


# ── Development / Testing (.env.local-dev) ───────────────────────────────────
# Used by: Playwright MCP browser tests (not deployed to servers)

MONCTL_TEST_USER=admin
MONCTL_TEST_PASSWORD=<admin-password>
MONCTL_BASE_URL=https://10.0.0.40
