ed before storage.","operationId":"create_credential_v1_credentials_post","parameters":[{"name":"Authorization","in":"header","required":true,"schema":{"type":"string","title":"Authorization"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateCredentialRequest"}}}},"responses":{"201":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/credentials/{credential_id}":{"get":{"tags":["credentials"],"summary":"Get Credential","description":"Get credential metadata by ID (no secret values).","operationId":"get_credential_v1_credentials__credential_id__get","parameters":[{"name":"credential_id","in":"path","required":true,"schema":{"type":"string","title":"Credential Id"}},{"name":"Authorization","in":"header","required":true,"schema":{"type":"string","title":"Authorization"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}},"put":{"tags":["credentials"],"summary":"Update Credential","description":"Update a credential. If secret is provided, it replaces the existing secret.","operationId":"update_credential_v1_credentials__credential_id__put","parameters":[{"name":"credential_id","in":"path","required":true,"schema":{"type":"string","title":"Credential Id"}},{"name":"Authorization","in":"header","required":true,"schema":{"type":"string","title":"Authorization"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateCredentialRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}},"delete":{"tags":["credentials"],"summary":"Delete Credential","description":"Delete a credential.","operationId":"delete_credential_v1_credentials__credential_id__delete","parameters":[{"name":"credential_id","in":"path","required":true,"schema":{"type":"string","title":"Credential Id"}},{"name":"Authorization","in":"header","required":true,"schema":{"type":"string","title":"Authorization"}}],"responses":{"204":{"description":"Successful Response"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"AppResult":{"properties":{"assignment_id":{"type":"string","title":"Assignment Id","description":"Assignment UUID that produced this result"},"app_id":{"type":"string","title":"App Id","description":"App UUID"},"check_result":{"$ref":"#/components/schemas/CheckResult"},"executed_at":{"type":"string","format":"date-time","title":"Executed At","description":"When the check was executed"}},"type":"object","required":["assignment_id","app_id","check_result","executed_at"],"title":"AppResult","description":"Complete result from a single app execution."},"CheckResult":{"properties":{"state":{"$ref":"#/components/schemas/CheckState","description":"Check state (0=OK, 1=WARN, 2=CRIT, 3=UNKNOWN)"},"output":{"type":"string","title":"Output","description":"Human-readable check output"},"metrics":{"items":{"$ref":"#/components/schemas/Metric"},"type":"array","title":"Metrics","description":"Metrics produced by the check"},"performance_data":{"additionalProperties":{"type":"number"},"type":"object","title":"Performance Data","description":"Performance data key-value pairs"},"execution_time":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Execution Time","description":"Execution time in seconds"}},"type":"object","required":["state","output"],"title":"CheckResult","description":"Result of a monitoring check execution."},"CheckState":{"type":"integer","enum":[0,1,2,3],"title":"CheckState","description":"State of a monitoring check result."},"CreateAlertRuleRequest":{"properties":{"name":{"type":"string","title":"Name"},"description":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Description"},"rule_type":{"type":"string","title":"Rule Type","description":"'threshold', 'absence', or 'state_change'"},"condition":{"additionalProperties":true,"type":"object","title":"Condition"},"severity":{"type":"string","title":"Severity","description":"'warning' or 'critical'"},"notification_channels":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Notification Channels"}},"type":"object","required":["name","rule_type","condition","severity"],"title":"CreateAlertRuleRequest"},"CreateAppRequest":{"properties":{"name":{"type":"string","title":"Name"},"description":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Description"},"app_type":{"type":"string","title":"App Type","description":"'script' or 'sdk'"},"config_schema":{"anyOf":[{"additionalProperties":true,"type":"object"},{"type":"null"}],"title":"Config Schema"}},"type":"object","required":["name","app_type"],"title":"CreateAppRequest","examples":[{"summary":"Script-based app","value":{"app_type":"script","description":"ICMP ping reachability check","name":"ping_check"}},{"summary":"HTTP check app","value":{"app_type":"script","description":"HTTP/HTTPS reachability and response time check","name":"http_check"}}]},"CreateAssignmentRequest":{"properties":{"app_id":{"type":"string","title":"App Id"},"app_version_id":{"type":"string","title":"App Version Id"},"collector_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Collector Id"},"cluster_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Cluster Id"},"device_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Device Id","description":"Optional device UUID. The device's address is auto-injected as `host` in the app config."},"config":{"additionalProperties":true,"type":"object","title":"Config","description":"App-specific config. Values starting with `$credential:<name>` are resolved to the decrypted secret before the config is sent to the collector."},"schedule_type":{"type":"string","title":"Schedule Type","description":"'interval' (seconds) or 'cron' (cron expression)"},"schedule_value":{"type":"string","title":"Schedule Value","description":"Seconds for interval (e.g. '60') or cron expression (e.g. '*/5 * * * *')"},"resource_limits":{"additionalProperties":true,"type":"object","title":"Resource Limits"}},"type":"object","required":["app_id","app_version_id","schedule_type","schedule_value"],"title":"CreateAssignmentRequest","examples":[{"description":"Link a ping_check assignment to a device. The device's address is automatically injected as `host` in the app config. Schedule: every 60 seconds.","summary":"Ping check — device-linked (address auto-injected)","value":{"app_id":"<ping_check app UUID>","app_version_id":"<app version UUID>","collector_id":"<collector UUID>","config":{"count":3,"timeout":2},"device_id":"<device UUID>","schedule_type":"interval","schedule_value":"60"}},{"description":"HTTP check where the device address is used as the URL. `$credential:` references are resolved server-side before the config is sent to the collector — the collector receives the plaintext value.","summary":"HTTP check — device-linked with credential","value":{"app_id":"<http_check app UUID>","app_version_id":"<app version UUID>","collector_id":"<collector UUID>","config":{"api_key":"$credential:my-api-key","expected_status":[200,201],"timeout":10},"device_id":"<device UUID>","schedule_type":"interval","schedule_value":"120"}},{"description":"Direct assignment without a device record — target is embedded in config.","summary":"Ping check — inline host (no device)","value":{"app_id":"<ping_check app UUID>","app_version_id":"<app version UUID>","collector_id":"<collector UUID>","config":{"count":3,"host":"localhost","timeout":2},"schedule_type":"interval","schedule_value":"30"}},{"description":"Run every 5 minutes using a cron expression.","summary":"Cron schedule","value":{"app_id":"<app UUID>","app_version_id":"<version UUID>","collector_id":"<collector UUID>","config":{},"device_id":"<device UUID>","schedule_type":"cron","schedule_value":"*/5 * * * *"}}]},"CreateCredentialRequest":{"properties":{"name":{"type":"string","title":"Name","description":"Unique reference name used in config: `$credential:<name>`"},"description":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Description"},"credential_type":{"type":"string","title":"Credential Type","description":"Type hint: 'snmp_community', 'ssh_password', 'api_key', 'token', etc."},"secret":{"additionalProperties":true,"type":"object","title":"Secret","description":"The secret key-value pairs. Encrypted with AES-256-GCM before storage. Never returned by the API. Keys are injected into the app config when the `$credential:name` reference is resolved."}},"type":"object","required":["name","credential_type","secret"],"title":"CreateCredentialRequest","examples":[{"summary":"SNMP community string","value":{"credential_type":"snmp_community","description":"Production SNMP v2c read community","name":"snmp-prod-community","secret":{"community":"mySecretCommunity","version":"2c"}}},{"summary":"SSH credentials","value":{"credential_type":"ssh_password","description":"Admin SSH login for Linux hosts","name":"linux-admin-ssh","secret":{"password":"s3cr3t!","username":"admin"}}},{"summary":"API key / token","value":{"credential_type":"api_key","description":"Datadog read-only API key","name":"datadog-api-key","secret":{"key":"dd-api-abc123xyz"}}}]},"CreateDeviceRequest":{"properties":{"name":{"type":"string","title":"Name","description":"Human-readable device name, e.g. 'prod-db-01'"},"address":{"type":"string","title":"Address","description":"IP address, hostname, or URL"},"device_type":{"type":"s