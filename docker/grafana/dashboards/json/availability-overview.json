{
  "uid": "availability-overview",
  "title": "Availability Overview",
  "description": "Uptime, response times, reachability heatmap",
  "tags": ["monctl"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "device",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "" },
        "query": "SELECT DISTINCT device_name FROM availability_latency_latest FINAL WHERE device_name != '' ORDER BY device_name",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overall Availability %",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT countIf(reachable = 1) * 100.0 / count() AS availability_pct FROM availability_latency WHERE $__timeFilter(executed_at) AND device_name IN ($device)",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "title": "Average Response Time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT $__timeInterval(executed_at) AS time, device_name, avg(rtt_ms) AS avg_rtt FROM availability_latency WHERE device_name IN ($device) AND $__timeFilter(executed_at) AND rtt_ms > 0 GROUP BY time, device_name ORDER BY time",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Availability Heatmap",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT $__timeInterval(executed_at) AS time, device_name, avg(reachable) * 100 AS availability FROM availability_latency WHERE device_name IN ($device) AND $__timeFilter(executed_at) GROUP BY time, device_name ORDER BY time",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "continuous-GrYlRd" },
          "custom": { "fillOpacity": 50 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 4,
      "title": "Currently Unreachable Devices",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT device_name, app_name, output, rtt_ms, executed_at FROM availability_latency_latest FINAL WHERE reachable = 0 AND device_id != toUUID('00000000-0000-0000-0000-000000000000') ORDER BY executed_at DESC",
          "format": 2,
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-24h", "to": "now" }
}
