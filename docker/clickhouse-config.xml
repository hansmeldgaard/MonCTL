<clickhouse>
    <!-- Use IP instead of hostname for interserver communication -->
    <interserver_http_host from_env="INTERSERVER_HTTP_HOST" />

    <remote_servers>
        <monctl_cluster>
            <shard>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>10.145.210.43</host>
                    <port>9000</port>
                    <user>monctl</user>
                    <password>monctl</password>
                </replica>
                <replica>
                    <host>10.145.210.44</host>
                    <port>9000</port>
                    <user>monctl</user>
                    <password>monctl</password>
                </replica>
            </shard>
        </monctl_cluster>
    </remote_servers>

    <macros>
        <cluster>monctl_cluster</cluster>
        <shard>1</shard>
        <replica from_env="CLICKHOUSE_REPLICA" />
    </macros>

    <zookeeper>
        <!-- ClickHouse Keeper (built-in) for replication coordination -->
        <node>
            <host>10.145.210.43</host>
            <port>9181</port>
        </node>
        <node>
            <host>10.145.210.44</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Enable built-in ClickHouse Keeper -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id from_env="KEEPER_SERVER_ID" />
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>10.145.210.43</hostname>
                <port>9234</port>
            </server>
            <server>
                <id>2</id>
                <hostname>10.145.210.44</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
