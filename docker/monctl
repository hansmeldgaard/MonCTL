#!/usr/bin/env bash
# monctl — Collector management CLI
# Install: sudo cp docker/monctl /usr/local/bin/monctl && sudo chmod +x /usr/local/bin/monctl
#
# Usage:
#   monctl status            Show collector status (health, workers, system)
#   monctl setup             Register collector with central (interactive)
#   monctl setup --url URL --code CODE   Non-interactive registration
#   monctl configure --url URL --key KEY   Update central URL / API key
#   monctl check             Check registration status
#   monctl raw <endpoint>    Raw GET request to status API (e.g. monctl raw /status)

set -euo pipefail

CACHE_NODE="${MONCTL_CACHE_NODE:-http://127.0.0.1:50052}"
CURL_OPTS="-s --connect-timeout 3 --max-time 10"

# ── Helpers ──────────────────────────────────────────────────────────────────

_has_jq() { command -v jq &>/dev/null; }

_pretty() {
    if _has_jq; then
        jq .
    elif command -v python3 &>/dev/null; then
        python3 -m json.tool
    else
        cat
    fi
}

_bar() {
    # Progress bar: _bar 60 20  →  [████████████░░░░░░░░]
    local pct=$1 width=${2:-20}
    local filled=$(( width * pct / 100 ))
    local empty=$(( width - filled ))
    local bar=""
    local i
    for (( i=0; i<filled; i++ )); do bar+="█"; done
    for (( i=0; i<empty; i++ )); do bar+="░"; done
    printf '[%s]' "$bar"
}

_err() { echo "ERROR: $*" >&2; }

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_status() {
    local resp
    resp=$(curl $CURL_OPTS "$CACHE_NODE/health" 2>/dev/null) || {
        _err "Cannot reach cache-node at $CACHE_NODE"
        _err "Is the collector running? Try: docker compose ps"
        exit 1
    }

    if _has_jq; then
        echo "=== MonCTL Collector Status ==="
        echo ""
        echo "Node:       $(echo "$resp" | jq -r '.node_id')"
        echo "Central:    $(echo "$resp" | jq -r '.central_url') ($(echo "$resp" | jq -r 'if .central_connected then "connected" else "disconnected" end'))"
        echo "Collector:  $(echo "$resp" | jq -r '.collector_id // "not registered"')"
        echo "Status:     $(echo "$resp" | jq -r '.registration_status')"
        echo "Uptime:     $(echo "$resp" | jq -r '.uptime_seconds')s"
        echo ""
        echo "--- Workers ---"
        echo "$resp" | jq -r '.workers[] | "  \(.worker_id)  jobs=\(.job_count)  last_seen=\(.last_seen)"'
        echo ""
        echo "--- Load ---"
        echo "$resp" | jq -r '"  Jobs: \(.load.total_jobs)  Score: \(.load.load_score)  Workers: \(.load.worker_count)  Miss rate: \(.load.deadline_miss_rate)"'
        echo ""
        echo "--- System ---"
        echo "$resp" | jq -r '"  CPU load: \(.system.cpu_load | join(", "))  (cores: \(.system.cpu_count))"'
        local mem_pct
        mem_pct=$(echo "$resp" | jq -r 'if .system.memory_total_mb > 0 then (.system.memory_used_mb * 100 / .system.memory_total_mb | floor) else 0 end')
        echo "  RAM:  $(_bar "$mem_pct") $(echo "$resp" | jq -r '.system.memory_used_mb')/$(echo "$resp" | jq -r '.system.memory_total_mb') MB ($mem_pct%)"
        local disk_pct
        disk_pct=$(echo "$resp" | jq -r 'if .system.disk_total_gb > 0 then (.system.disk_used_gb * 100 / .system.disk_total_gb | floor) else 0 end')
        echo "  Disk: $(_bar "$disk_pct") $(echo "$resp" | jq -r '.system.disk_used_gb')/$(echo "$resp" | jq -r '.system.disk_total_gb') GB ($disk_pct%)"
    else
        echo "$resp" | _pretty
    fi
}

cmd_setup() {
    local url="" code=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url)  url="$2"; shift 2 ;;
            --code) code="$2"; shift 2 ;;
            *)      shift ;;
        esac
    done

    # Interactive fallback
    if [[ -z "$url" ]]; then
        read -rp "Central URL: " url
    fi
    if [[ -z "$code" ]]; then
        read -rp "Registration Code: " code
    fi

    if [[ -z "$url" || -z "$code" ]]; then
        _err "Both URL and registration code are required"
        exit 1
    fi

    echo "Registering with $url..."
    local resp
    resp=$(curl $CURL_OPTS -X POST "$CACHE_NODE/setup/register" \
        -H "Content-Type: application/json" \
        -d "{\"central_url\": \"$url\", \"registration_code\": \"$code\"}" 2>/dev/null) || {
        _err "Cannot reach cache-node at $CACHE_NODE"
        exit 1
    }

    echo "$resp" | _pretty

    # Hint about restart
    if echo "$resp" | grep -q '"status".*"registered"'; then
        echo ""
        echo "Registration successful! Restart collector to apply:"
        echo "  cd /opt/monctl/collector && docker compose restart"
    fi
}

cmd_configure() {
    local url="" key=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url) url="$2"; shift 2 ;;
            --key) key="$2"; shift 2 ;;
            *)     shift ;;
        esac
    done

    if [[ -z "$url" && -z "$key" ]]; then
        _err "Provide --url and/or --key"
        exit 1
    fi

    local payload="{"
    [[ -n "$url" ]] && payload+="\"central_url\": \"$url\""
    [[ -n "$url" && -n "$key" ]] && payload+=", "
    [[ -n "$key" ]] && payload+="\"api_key\": \"$key\""
    payload+="}"

    local resp
    resp=$(curl $CURL_OPTS -X POST "$CACHE_NODE/setup/configure" \
        -H "Content-Type: application/json" \
        -d "$payload" 2>/dev/null) || {
        _err "Cannot reach cache-node at $CACHE_NODE"
        exit 1
    }

    echo "$resp" | _pretty
}

cmd_check() {
    local resp
    resp=$(curl $CURL_OPTS "$CACHE_NODE/setup/check" 2>/dev/null) || {
        _err "Cannot reach cache-node at $CACHE_NODE"
        exit 1
    }
    echo "$resp" | _pretty
}

cmd_raw() {
    local endpoint="${1:-/status}"
    curl $CURL_OPTS "$CACHE_NODE$endpoint" 2>/dev/null | _pretty
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-status}" in
    status)              cmd_status ;;
    setup)        shift; cmd_setup "$@" ;;
    configure)    shift; cmd_configure "$@" ;;
    check)               cmd_check ;;
    raw)          shift; cmd_raw "$@" ;;
    -h|--help|help)
        echo "Usage: monctl <command>"
        echo ""
        echo "Commands:"
        echo "  status              Show collector health, workers, system"
        echo "  setup [--url URL --code CODE]  Register with central"
        echo "  configure --url URL --key KEY  Update central connection"
        echo "  check               Check registration status"
        echo "  raw <endpoint>      Raw GET to status API"
        echo ""
        echo "Environment:"
        echo "  MONCTL_CACHE_NODE   Status API URL (default: http://127.0.0.1:50052)"
        ;;
    *)
        _err "Unknown command: $1"
        echo "Run 'monctl help' for usage"
        exit 1
        ;;
esac
