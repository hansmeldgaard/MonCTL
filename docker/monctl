#!/usr/bin/env bash
# monctl вҖ” Collector management CLI
# Install: sudo cp docker/monctl /usr/local/bin/monctl && sudo chmod +x /usr/local/bin/monctl
#
# Usage:
#   monctl status            Show collector status (health, workers, system)
#   monctl raw <endpoint>    Raw GET request to status API (e.g. monctl raw /status)

set -euo pipefail

CACHE_NODE="${MONCTL_CACHE_NODE:-http://127.0.0.1:50052}"
CURL_OPTS="-s --connect-timeout 3 --max-time 10"

# в”Җв”Җ Helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

_has_jq() { command -v jq &>/dev/null; }

_pretty() {
    if _has_jq; then
        jq .
    elif command -v python3 &>/dev/null; then
        python3 -m json.tool
    else
        cat
    fi
}

_bar() {
    # Progress bar: _bar 60 20  вҶ’  [в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘]
    local pct=$1 width=${2:-20}
    local filled=$(( width * pct / 100 ))
    local empty=$(( width - filled ))
    local bar=""
    local i
    for (( i=0; i<filled; i++ )); do bar+="в–Ҳ"; done
    for (( i=0; i<empty; i++ )); do bar+="в–‘"; done
    printf '[%s]' "$bar"
}

_err() { echo "ERROR: $*" >&2; }

# в”Җв”Җ Commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

cmd_status() {
    local resp
    resp=$(curl $CURL_OPTS "$CACHE_NODE/health" 2>/dev/null) || {
        _err "Cannot reach cache-node at $CACHE_NODE"
        _err "Is the collector running? Try: docker compose ps"
        exit 1
    }

    if _has_jq; then
        echo "=== MonCTL Collector Status ==="
        echo ""
        echo "Node:       $(echo "$resp" | jq -r '.node_id')"
        echo "Central:    $(echo "$resp" | jq -r '.central_url') ($(echo "$resp" | jq -r 'if .central_connected then "connected" else "disconnected" end'))"
        echo "Collector:  $(echo "$resp" | jq -r '.collector_id // "not registered"')"
        echo "Status:     $(echo "$resp" | jq -r '.registration_status')"
        echo "Uptime:     $(echo "$resp" | jq -r '.uptime_seconds')s"
        echo ""
        echo "--- Workers ---"
        echo "$resp" | jq -r '.workers[] | "  \(.worker_id)  jobs=\(.job_count)  last_seen=\(.last_seen)"'
        echo ""
        echo "--- Load ---"
        echo "$resp" | jq -r '"  Jobs: \(.load.total_jobs)  Score: \(.load.load_score)  Workers: \(.load.worker_count)  Miss rate: \(.load.deadline_miss_rate)"'
        echo ""
        echo "--- System ---"
        echo "$resp" | jq -r '"  CPU load: \(.system.cpu_load | join(", "))  (cores: \(.system.cpu_count))"'
        local mem_pct
        mem_pct=$(echo "$resp" | jq -r 'if .system.memory_total_mb > 0 then (.system.memory_used_mb * 100 / .system.memory_total_mb | floor) else 0 end')
        echo "  RAM:  $(_bar "$mem_pct") $(echo "$resp" | jq -r '.system.memory_used_mb')/$(echo "$resp" | jq -r '.system.memory_total_mb') MB ($mem_pct%)"
        local disk_pct
        disk_pct=$(echo "$resp" | jq -r 'if .system.disk_total_gb > 0 then (.system.disk_used_gb * 100 / .system.disk_total_gb | floor) else 0 end')
        echo "  Disk: $(_bar "$disk_pct") $(echo "$resp" | jq -r '.system.disk_used_gb')/$(echo "$resp" | jq -r '.system.disk_total_gb') GB ($disk_pct%)"
    else
        echo "$resp" | _pretty
    fi
}

cmd_raw() {
    local endpoint="${1:-/status}"
    curl $CURL_OPTS "$CACHE_NODE$endpoint" 2>/dev/null | _pretty
}

# в”Җв”Җ Main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

case "${1:-status}" in
    status)              cmd_status ;;
    raw)          shift; cmd_raw "$@" ;;
    -h|--help|help)
        echo "Usage: monctl <command>"
        echo ""
        echo "Commands:"
        echo "  status              Show collector health, workers, system"
        echo "  raw <endpoint>      Raw GET to status API"
        echo ""
        echo "Environment:"
        echo "  MONCTL_CACHE_NODE   Status API URL (default: http://127.0.0.1:50052)"
        ;;
    *)
        _err "Unknown command: $1"
        echo "Run 'monctl help' for usage"
        exit 1
        ;;
esac
