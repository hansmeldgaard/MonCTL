# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
# monctl_ctl .env.j2 templates live under an "env/" dir; keep them tracked.
!packages/installer/src/monctl_installer/render/templates/env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Docker
docker/pgdata/
docker/vmdata/
docker/redis-data/

# Collector local data
*.db
*.key

# Playwright local dev artifacts (auth state, screenshots, snapshots)
.playwright/
# Ad-hoc verification screenshots + snapshots dumped at repo root during
# Playwright/MCP sessions. Root-scoped so nothing inside subdirs is hidden.
/*.png
/*.yml

# Claude Code
.claude/audit/
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Stray .claude/ dirs that get created when Claude is invoked from a subdir
packages/**/.claude/
.mcp.json
.playwright-mcp/

# TLS certificates
docker/certs/

# e2e smoke baseline snapshots (scripts/e2e_smoke.py)
.monctl-smoke/

# monctl_ctl installer output + customer secrets
/out/
/secrets.env
/inventory.yaml
