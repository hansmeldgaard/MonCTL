<!-- Dedicated ClickHouse Keeper — rendered by monctl_ctl for {{ host.name }} -->
<clickhouse>
    <listen_host>0.0.0.0</listen_host>
    <keeper_server>
        <tcp_port>9181</tcp_port>
{% set this_keeper_index = plan.clickhouse_keepers | map(attribute='name') | list %}
        <server_id>{{ this_keeper_index.index(host.name) + 1 }}</server_id>
        <log_storage_path>/var/lib/clickhouse-keeper/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse-keeper/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
        </coordination_settings>
        <raft_configuration>
{% for k in plan.clickhouse_keepers %}
            <server>
                <id>{{ loop.index }}</id>
                <hostname>{{ k.address }}</hostname>
                <port>9234</port>
            </server>
{% endfor %}
        </raft_configuration>
    </keeper_server>
</clickhouse>
