# Central on {{ host.name }}
# Secrets sourced from ./secrets.env
PG_PASSWORD=${PG_PASSWORD}
CLICKHOUSE_PASSWORD=${CLICKHOUSE_PASSWORD}
MONCTL_ENCRYPTION_KEY=${MONCTL_ENCRYPTION_KEY}
MONCTL_JWT_SECRET_KEY=${MONCTL_JWT_SECRET_KEY}
MONCTL_COLLECTOR_API_KEY=${MONCTL_COLLECTOR_API_KEY}
MONCTL_ADMIN_PASSWORD=${MONCTL_ADMIN_PASSWORD}
{% if plan.superset_host %}
MONCTL_OAUTH_CLIENT_ID=${MONCTL_OAUTH_CLIENT_ID}
MONCTL_OAUTH_CLIENT_SECRET=${MONCTL_OAUTH_CLIENT_SECRET}
# OIDC issuer claim — public base URL operators see in their browser.
# Falls back to first central host:8443 when no VIP is configured.
{% if cluster.vip %}
MONCTL_OAUTH_ISSUER=https://{{ cluster.vip }}
MONCTL_OAUTH_REDIRECT_URIS=https://{{ cluster.vip }}/bi/oauth-authorized/monctl
{% else %}
MONCTL_OAUTH_ISSUER=https://{{ plan.central_hosts[0].address }}:8443
MONCTL_OAUTH_REDIRECT_URIS=https://{{ plan.central_hosts[0].address }}:8443/bi/oauth-authorized/monctl
{% endif %}
{% endif %}
