# HAProxy + keepalived on {{ host.name }}
KEEPALIVED_INTERFACE={{ cluster.vip_interface | default('eth0') }}
{# Priority descends with host index so one node is deterministically MASTER. #}
{% set idx = plan.haproxy_hosts | map(attribute='name') | list %}
KEEPALIVED_PRIORITY={{ 100 - idx.index(host.name) }}
