# Superset on {{ host.name }}
# Secrets sourced from ./secrets.env (populated by monctl_ctl init).
SUPERSET_SECRET_KEY=${SUPERSET_SECRET_KEY}
SUPERSET_DB_PW=${SUPERSET_DB_PW}
SUPERSET_ADMIN_USER={{ 'admin' }}
SUPERSET_ADMIN_PW=${SUPERSET_ADMIN_PW}
SUPERSET_ADMIN_EMAIL=admin@monctl.local

# OAuth — central must have a matching OAuth2 client row keyed by these values.
# Central seeds it from the same secrets.env at lifespan startup.
MONCTL_OAUTH_CLIENT_ID=${MONCTL_OAUTH_CLIENT_ID}
MONCTL_OAUTH_CLIENT_SECRET=${MONCTL_OAUTH_CLIENT_SECRET}

# URLs central + browsers use to reach each other.
{% if cluster.vip %}
MONCTL_PUBLIC_BASE=https://{{ cluster.vip }}
SUPERSET_PUBLIC_ORIGIN=https://{{ cluster.vip }}
{% else %}
MONCTL_PUBLIC_BASE=https://{{ plan.central_hosts[0].address }}:8443
SUPERSET_PUBLIC_ORIGIN=https://{{ plan.central_hosts[0].address }}:8443
{% endif %}
MONCTL_INTERNAL_BASE={{ central_internal_url }}

# ClickHouse connection used by superset-init.
CLICKHOUSE_SUPERSET_USER=monctl
CLICKHOUSE_SUPERSET_PW=${CLICKHOUSE_PASSWORD}
CLICKHOUSE_HOST_PRIMARY={{ clickhouse_first_host }}
CLICKHOUSE_DB=monctl
