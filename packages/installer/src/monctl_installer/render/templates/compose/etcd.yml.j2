# etcd — rendered by monctl_ctl for {{ host.name }}
services:
  etcd:
    image: quay.io/coreos/etcd:v3.5.17
    container_name: etcd
    network_mode: host
    environment:
      ETCD_NAME: {{ host.name }}
      ETCD_DATA_DIR: /etcd-data
      ETCD_LISTEN_CLIENT_URLS: http://0.0.0.0:2379
      ETCD_LISTEN_PEER_URLS: http://0.0.0.0:2380
      ETCD_ADVERTISE_CLIENT_URLS: http://{{ host.address }}:2379
      ETCD_INITIAL_ADVERTISE_PEER_URLS: http://{{ host.address }}:2380
      ETCD_INITIAL_CLUSTER: {% for h in plan.etcd_hosts %}{{ h.name }}=http://{{ h.address }}:2380{% if not loop.last %},{% endif %}{% endfor %}

      ETCD_INITIAL_CLUSTER_STATE: new
      ETCD_INITIAL_CLUSTER_TOKEN: monctl-etcd-cluster
    volumes:
      - etcd_data:/etcd-data
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "etcdctl", "endpoint", "health"]
      interval: 10s
      timeout: 5s
      retries: 3

volumes:
  etcd_data:
