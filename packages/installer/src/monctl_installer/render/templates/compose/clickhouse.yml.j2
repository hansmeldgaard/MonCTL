# ClickHouse on {{ host.name }} — shard {{ ch_node.shard }} replica {{ ch_node.replica }}
services:
  clickhouse:
    image: clickhouse/clickhouse-server:24.3-alpine
    container_name: clickhouse
    network_mode: host
    environment:
      CLICKHOUSE_DB: monctl
      CLICKHOUSE_USER: monctl
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD}
      CLICKHOUSE_REPLICA: ch{{ ch_node.shard }}r{{ ch_node.replica }}
{% if ch_node.embedded_keeper %}
      KEEPER_SERVER_ID: "{{ ch_node.keeper_id }}"
{% endif %}
      INTERSERVER_HTTP_HOST: {{ host.address }}
    volumes:
      - ch_data:/var/lib/clickhouse
      - ch_logs:/var/log/clickhouse-server
      - ./clickhouse-config.xml:/etc/clickhouse-server/config.d/cluster.xml:ro
    ulimits:
      nofile:
        soft: 262144
        hard: 262144
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "clickhouse-client", "--query", "SELECT 1"]
      interval: 10s
      timeout: 5s
      retries: 3

volumes:
  ch_data:
  ch_logs:
